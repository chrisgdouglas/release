{
    "name": "chrisdouglas/photo-release",
    "description": "Photo release consent form with QR onboarding",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1.2",
        "phpmailer/phpmailer": "^6.10",
        "chillerlan/php-qrcode": "^5.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse"
    }
}
